# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values
# cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/bakery?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/bakery?retryWrites=true&w=majority

# JWT signing secret — use a long random string in production
SECRET_KEY=supersecretkey-change-me-in-production
