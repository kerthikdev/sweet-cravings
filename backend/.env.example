# ──────────────────────────────────────────────────────────────────────────────
# Sweet Cravings Bakery — Backend Environment Template
#
# Copy to .env and fill in real values:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────────────────
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?...
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/bakery?retryWrites=true&w=majority
MONGO_DB_NAME=bakery

# ── Auth ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
JWT_EXPIRY_HOURS=8

# ── Flask runtime ───────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1

# ── Service ports ───────────────────────────────────────────────────────────
USER_SERVICE_PORT=5001
PRODUCT_SERVICE_PORT=5002
ORDER_SERVICE_PORT=5003
PAYMENT_SERVICE_PORT=5004
API_GATEWAY_PORT=5050

# ── Internal service URLs (local dev: localhost; docker: service names) ──────
USER_SERVICE_URL=http://localhost:5001
PRODUCT_SERVICE_URL=http://localhost:5002
ORDER_SERVICE_URL=http://localhost:5003
PAYMENT_SERVICE_URL=http://localhost:5004
