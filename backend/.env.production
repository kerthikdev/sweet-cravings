# ─────────────────────────────────────────────────────────────
# Sweet Cravings Bakery — Production Environment
# Used by: Docker / deployment server
# ─────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────
MONGO_URI=mongodb+srv://admin:admin@mongo.s2gflbj.mongodb.net/bakery?retryWrites=true&w=majority&appName=mongo
MONGO_DB_NAME=bakery

# ── Auth ─────────────────────────────────────────────────────
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRY_HOURS=8

# ── Flask Runtime ────────────────────────────────────────────
FLASK_ENV=production
FLASK_DEBUG=0

# ── Service Ports ────────────────────────────────────────────
USER_SERVICE_PORT=5001
PRODUCT_SERVICE_PORT=5002
ORDER_SERVICE_PORT=5003
PAYMENT_SERVICE_PORT=5004
API_GATEWAY_PORT=5050

# Frontend container / reverse proxy
FRONTEND_PORT=3000

# ── Service Hosts (Docker service names) ─────────────────────
USER_SERVICE_HOST=user_service
PRODUCT_SERVICE_HOST=product_service
ORDER_SERVICE_HOST=order_service
PAYMENT_SERVICE_HOST=payment_service

# ── Internal Service URLs ────────────────────────────────────
USER_SERVICE_URL=http://user_service:5001
PRODUCT_SERVICE_URL=http://product_service:5002
ORDER_SERVICE_URL=http://order_service:5003
PAYMENT_SERVICE_URL=http://payment_service:5004