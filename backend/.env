# ── Database ─────────────────────────────────────────────────
MONGO_URI=mongodb+srv://admin:admin@mongo.s2gflbj.mongodb.net/bakery?retryWrites=true&w=majority&appName=mongo
MONGO_DB_NAME=bakery

# ── Auth ─────────────────────────────────────────────────────
SECRET_KEY=supersecretkey-dev
JWT_EXPIRY_HOURS=8

# ── Flask Runtime ────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1

# ── Service Ports ────────────────────────────────────────────
USER_SERVICE_PORT=5001
PRODUCT_SERVICE_PORT=5002
ORDER_SERVICE_PORT=5003
PAYMENT_SERVICE_PORT=5004
API_GATEWAY_PORT=5050

# Frontend dev server
FRONTEND_PORT=5173

# ── Service Hosts (Local) ────────────────────────────────────
USER_SERVICE_HOST=localhost
PRODUCT_SERVICE_HOST=localhost
ORDER_SERVICE_HOST=localhost
PAYMENT_SERVICE_HOST=localhost

# ── Internal Service URLs ────────────────────────────────────
