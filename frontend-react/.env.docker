# ──────────────────────────────────────────────────────────────────────────────
# FRONTEND ENVIRONMENT (Docker Compose)
# ──────────────────────────────────────────────────────────────────────────────

# Vite build — leave empty, browser uses relative /api paths via Nginx proxy
VITE_API_GATEWAY_URL=

# Nginx runtime — host and port are SEPARATE so Nginx resolver works correctly
# Docker Compose uses service names:
API_GATEWAY_HOST=api_gateway
API_GATEWAY_PORT=5050

VITE_DEV_PORT=5173
